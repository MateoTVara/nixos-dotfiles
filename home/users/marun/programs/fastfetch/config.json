{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        "source": "nixos_small",
        "color": {
            "1": "#F7EC31",
            "2": "#F7F7F7",
            "3": "#9656C9",
            "4": "#2B2B2B",
            "5": "#F7F7F7",
            "6": "#9656C9"
        },
        "preserveAspectRatio": true,
        "padding": {
            "left": 4
        }
    },
    "display": {
        "separator": "->   ",
        "color": {
            "separator": "#F7EC31"
        }
    },
    "modules": [
        {
            "key": "Distro      ",
            "type": "os",
            "keyColor": "#9656C9",
            "outputColor": "#F7F7F7"
        },
        {
            "key": "WM          ",
            "type": "wm",
            "keyColor": "#9656C9",
            "outputColor": "#F7F7F7"
        },
        {
            "key": "Shell       ",
            "type": "shell",
            "keyColor": "#9656C9",
            "outputColor": "#F7F7F7"
        },
        {
            "key": "Terminal    ",
            "type": "terminal",
            "keyColor": "#9656C9",
            "outputColor": "#F7F7F7"
        },
        {
            "key": "Display     ",
            "type": "display",
            "keyColor": "#9656C9",
            "outputColor": "#F7F7F7"
        },
        {
            "key": "Backlight   ",
            "type": "brightness",
            "keyColor": "#9656C9",
            "outputColor": "#F7F7F7"
        },
        "break",
        {
            "type": "colors",
            "paddingLeft": 6,
            "symbol": "circle"
        }
    ]
}